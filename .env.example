# Скопируйте в .env и заполните, чтобы включить рабочий режим (реальный API).
# Без этих значений приложение работает в демо-режиме.

# Аутентификация (нужно ОДНО из двух):
YANDEX_API_KEY=
# YANDEX_IAM_TOKEN=

# Идентификатор каталога Yandex Cloud — ОБЯЗАТЕЛЕН для Wordstat API
# (передаётся как folderId в каждом запросе; без него API вернёт 403):
YANDEX_FOLDER_ID=

# --- Защита входа (опционально) ---
# Задайте APP_PASSWORD, чтобы закрыть сайт логином/паролем (HTTP Basic Auth).
# Без APP_PASSWORD сайт открыт. Логин по умолчанию — "otp".
# На публичном сайте используйте вместе с HTTPS (пароль иначе идёт base64).
# APP_USER=otp
# APP_PASSWORD=
